    { "source": "/amalfikueste.html",                  "destination": "/italien/amalfikueste/",              "permanent": true },

    { "source": "/beste-reisezeit-tuerkei.html",       "destination": "/tuerkei/reisezeit/",                 "permanent": true },
    { "source": "/beste-reisezeit-spanien.html",       "destination": "/spanien/reisezeit/",                 "permanent": true },
    { "source": "/beste-reisezeit-griechenland.html",  "destination": "/griechenland/reisezeit/",            "permanent": true },
    { "source": "/beste-reisezeit-aegypten.html",      "destination": "/aegypten/reisezeit/",                "permanent": true },
