    { "source": "/beste-reisezeit-dubai.html",         "destination": "/dubai/reisezeit/",                   "permanent": true },
    { "source": "/beste-reisezeit-portugal.html",      "destination": "/portugal/reisezeit/",                "permanent": true },
    { "source": "/beste-reisezeit-malta.html",         "destination": "/malta/reisezeit/",                   "permanent": true },

    { "source": "/urlaub-mit-kindern.html",            "destination": "/themen/urlaub-mit-kindern/",         "permanent": true },
    { "source": "/flitterwochen.html",                 "destination": "/themen/flitterwochen/",              "permanent": true },
    { "source": "/last-minute-urlaub.html",            "destination": "/themen/last-minute/",                "permanent": true },
    { "source": "/all-inclusive-urlaub.html",          "destination": "/themen/all-inclusive/",              "permanent": true },

    { "source": "/handgepaeck-regeln.html",            "destination": "/tipps/handgepaeck/",                 "permanent": true },
    { "source": "/reiseversicherung-vergleich.html",   "destination": "/tipps/reiseversicherung/",           "permanent": true },
    { "source": "/packliste-sommerurlaub.html",        "destination": "/tipps/packliste/",                   "permanent": true },
    { "source": "/guenstig-fliegen-tipps.html",        "destination": "/tipps/guenstig-fliegen/",            "permanent": true },

    { "source": "/tuerkei-vs-aegypten.html",           "destination": "/vergleiche/tuerkei-vs-aegypten/",    "permanent": true },
    { "source": "/mallorca-vs-kreta.html",             "destination": "/vergleiche/mallorca-vs-kreta/",      "permanent": true },
    { "source": "/dubai-vs-abu-dhabi.html",            "destination": "/vergleiche/dubai-vs-abu-dhabi/",     "permanent": true }
  ]
