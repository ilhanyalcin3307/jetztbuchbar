{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/booking/index.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, follow" }
      ]
    },
    {
      "source": "/deals",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, follow" }
      ]
    },
    {
      "source": "/deals/",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, follow" }
      ]
    },
    {
      "source": "/deals/index.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, follow" }
      ]
    },
    {
      "source": "/vergleich.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, follow" }
      ]
    },
    {
      "source": "/changelog.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "redirects": [
    { "source": "/booking",                            "destination": "/",                                  "permanent": true },
    { "source": "/booking/index.html",                 "destination": "/",                                  "permanent": true },
    { "source": "/hotel",                              "destination": "/hotel.html",                         "permanent": true },
    { "source": "/hotel/",                             "destination": "/hotel.html",                         "permanent": true },
    { "source": "/santorini/",                         "destination": "/griechenland/santorini/",            "permanent": true },
    { "source": "/abu-dhabi/",                         "destination": "/dubai/",                             "permanent": true },
    { "source": "/tuerkei.html",                      "destination": "/tuerkei/",                          "permanent": true },
    { "source": "/spanien.html",                       "destination": "/spanien/",                           "permanent": true },
    { "source": "/griechenland.html",                  "destination": "/griechenland/",                      "permanent": true },
    { "source": "/aegypten.html",                      "destination": "/aegypten/",                          "permanent": true },
    { "source": "/marokko.html",                       "destination": "/marokko/",                           "permanent": true },
    { "source": "/tunesien.html",                      "destination": "/tunesien/",                          "permanent": true },
    { "source": "/dubai.html",                         "destination": "/dubai/",                             "permanent": true },
    { "source": "/kroatien.html",                      "destination": "/kroatien/",                          "permanent": true },
    { "source": "/portugal.html",                      "destination": "/portugal/",                          "permanent": true },
    { "source": "/bulgarien.html",                     "destination": "/bulgarien/",                         "permanent": true },
    { "source": "/malta.html",                         "destination": "/malta/",                             "permanent": true },
    { "source": "/zypern.html",                        "destination": "/zypern/",                            "permanent": true },
    { "source": "/kap-verde.html",                     "destination": "/kap-verde/",                         "permanent": true },
    { "source": "/jordanien.html",                     "destination": "/jordanien/",                         "permanent": true },

    { "source": "/antalya.html",                       "destination": "/tuerkei/antalya/",                   "permanent": true },
    { "source": "/bodrum.html",                        "destination": "/tuerkei/bodrum/",                    "permanent": true },
    { "source": "/kreta-urlaub.html",                  "destination": "/griechenland/kreta/",                "permanent": true },
